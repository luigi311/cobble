// Shared data structures (generated as Rust structs via slint::include_modules!).

export struct DaySteps {
    label: string,
    steps-label: string,
    fraction: float,
    bar-start: int,
    bar-end: int,
}

export struct SleepBar {
    label: string,
    bar-start: int,
    bar-end: int,
    light-fraction: float,   // light sleep height / max night height
    deep-fraction: float,    // deep sleep height / max night height
    total-label: string,     // "7h 30m"
    deep-label: string,      // "2h 15m deep"
}

export struct HealthSession {
    type-name: string,
    start-label: string,
    duration-label: string,
    has-metrics: bool,
    metrics-label: string,
}

export struct WatchDevice {
    address: string,
    name: string,
}

export struct DeviceConfigEntry {
    group: string,
    label: string,
    value: string,
    status: string,
}

export struct SleepStats {
    deep-avg-label: string,
    light-pct: float,
    deep-pct: float,
    awake-pct: float,
    avg-bedtime: string,
    avg-wakeup: string,
    highest-dur: string,
    lowest-dur: string,
}

export struct HeartStats {
    average-label: string,
    resting-label: string,
    sleeping-label: string,
    lowest-label: string,
    highest-label: string,
    samples-label: string,
}

export struct HeartTrendPoint {
    label: string,
}
