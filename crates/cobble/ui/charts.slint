// Health-data chart and list components.

import { Palette } from "theme.slint";
import { DaySteps, SleepBar, HealthSession, SleepStats, HeartStats, HeartTrendPoint } from "types.slint";

// ─── Step bar chart ──────────────────────────────────────────────────────────

export component StepsChart inherits VerticalLayout {
    in property <[DaySteps]> model;
    in property <string> today-label;
    in property <string> avg-label;
    in property <string> delta-label;
    in property <bool> delta-positive: true;
    in-out property <int> selected-bar-start: -1;
    callback bar-tapped(int, int);

    padding: 16px; spacing: 10px;

    // Header: avg left, delta right (title is in the app header bar)
    HorizontalLayout {
        if root.avg-label != "": Text {
            text: root.avg-label;
            color: Palette.muted; font-size: 13px; vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
        if root.delta-label != "": Text {
            text: root.delta-label;
            color: root.delta-positive ? Palette.green : Palette.red;
            font-size: 13px; font-weight: 600; vertical-alignment: center;
        }
    }

    Rectangle {
        background: Palette.surface; border-radius: 12px; height: 200px; clip: true;
        HorizontalLayout {
            spacing: 4px; padding: 14px;
            for day in model: Rectangle {
                horizontal-stretch: 1;
                VerticalLayout {
                    Rectangle { vertical-stretch: 1; }
                    Rectangle {
                        background: (root.selected-bar-start == -1 || root.selected-bar-start == day.bar-start)
                                    ? Palette.accent : #4a9eff30;
                        border-radius: 3px;
                        height: max(4px, day.fraction * 148px);
                        animate background { duration: 150ms; easing: ease-in-out; }
                    }
                    Text {
                        text: day.label; color: Palette.muted; font-size: 10px;
                        horizontal-alignment: center; height: 18px;
                    }
                }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        if root.selected-bar-start == day.bar-start {
                            root.selected-bar-start = -1;
                            root.bar-tapped(-1, -1);
                        } else {
                            root.selected-bar-start = day.bar-start;
                            root.bar-tapped(day.bar-start, day.bar-end);
                        }
                    }
                }
            }
        }
    }
}

// ─── Sleep stacked bar chart ──────────────────────────────────────────────────

export component SleepChart inherits VerticalLayout {
    in property <[SleepBar]> model;
    in property <string> sleep-label;
    in property <string> avg-label;
    in property <string> delta-label;
    in property <bool> delta-positive: true;
    in-out property <int> selected-bar-start: -1;
    callback bar-tapped(int, int);

    padding: 16px; spacing: 10px;

    // Header: avg left, delta right (title is in the app header bar)
    HorizontalLayout {
        if root.avg-label != "": Text {
            text: root.avg-label;
            color: Palette.muted; font-size: 13px; vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
        if root.delta-label != "": Text {
            text: root.delta-label;
            color: root.delta-positive ? Palette.green : Palette.red;
            font-size: 13px; font-weight: 600; vertical-alignment: center;
        }
    }

    Rectangle {
        background: Palette.surface; border-radius: 12px; height: 200px; clip: true;
        HorizontalLayout {
            spacing: 4px; padding: 14px;
            for night in model: Rectangle {
                horizontal-stretch: 1;
                VerticalLayout {
                    Rectangle { vertical-stretch: 1; }
                    // Light sleep — top of bar stack
                    Rectangle {
                        background: (root.selected-bar-start == -1 || root.selected-bar-start == night.bar-start)
                                    ? Palette.accent : #4a9eff30;
                        height: night.light-fraction * 148px;
                        animate background { duration: 150ms; easing: ease-in-out; }
                    }
                    // Deep sleep — bottom of bar stack
                    Rectangle {
                        background: (root.selected-bar-start == -1 || root.selected-bar-start == night.bar-start)
                                    ? Palette.deep-sleep : #7c3aed30;
                        border-radius: 3px;
                        height: night.deep-fraction * 148px;
                        animate background { duration: 150ms; easing: ease-in-out; }
                    }
                    Text {
                        text: night.label; color: Palette.muted; font-size: 10px;
                        horizontal-alignment: center; height: 18px;
                    }
                }
                TouchArea {
                    width: parent.width; height: parent.height;
                    clicked => {
                        if root.selected-bar-start == night.bar-start {
                            root.selected-bar-start = -1;
                            root.bar-tapped(-1, -1);
                        } else {
                            root.selected-bar-start = night.bar-start;
                            root.bar-tapped(night.bar-start, night.bar-end);
                        }
                    }
                }
            }
        }
    }

    // Legend — at the bottom
    HorizontalLayout {
        spacing: 16px;
        HorizontalLayout {
            spacing: 5px;
            Rectangle { width: 10px; height: 10px; border-radius: 2px; background: Palette.accent; y: 2px; }
            Text { text: "Light"; color: Palette.muted; font-size: 11px; }
        }
        HorizontalLayout {
            spacing: 5px;
            Rectangle { width: 10px; height: 10px; border-radius: 2px; background: Palette.deep-sleep; y: 2px; }
            Text { text: "Deep"; color: Palette.muted; font-size: 11px; }
        }
    }
}

// ─── Session list ─────────────────────────────────────────────────────────────

export component SessionList inherits Flickable {
    in property <[HealthSession]> model;
    vertical-stretch: 1;
    viewport-height: items.preferred-height;
    items := VerticalLayout {
        alignment: start;
        for s in root.model: Rectangle {
            height: s.has-metrics ? 108px : 80px;
            Rectangle {
                x: 16px; y: 4px; width: parent.width - 32px; height: parent.height - 8px;
                background: Palette.surface; border-radius: 10px;
                VerticalLayout {
                    padding: 12px; spacing: 4px;
                    HorizontalLayout {
                        Text { text: s.type-name; color: Palette.text; font-size: 14px; font-weight: 600; vertical-alignment: center; }
                        Rectangle { horizontal-stretch: 1; }
                        Text { text: s.start-label; color: Palette.muted; font-size: 12px; vertical-alignment: center; }
                    }
                    Text { text: s.duration-label; color: Palette.muted; font-size: 13px; }
                    if s.has-metrics: Text { text: s.metrics-label; color: Palette.accent; font-size: 12px; }
                }
            }
        }
    }
}

// ─── Sleep stats panel ───────────────────────────────────────────────────────

export component SleepStatsPanel inherits VerticalLayout {
    in property <SleepStats> stats;

    vertical-stretch: 1;
    padding-left: 16px; padding-right: 16px; padding-top: 8px; padding-bottom: 16px;
    spacing: 10px;

    // Header: title
    HorizontalLayout {
        Text { text: "Key Stats"; color: Palette.text; font-size: 15px; font-weight: 700; vertical-alignment: center; }
        Rectangle { horizontal-stretch: 1; }
    }

    // Stats grid
    Rectangle {
        background: Palette.surface; border-radius: 12px;
        VerticalLayout {
            padding: 14px; spacing: 10px;

            // Row 1: Deep Sleep Avg | Stage Mix
            HorizontalLayout {
                spacing: 10px;
                // Deep sleep average
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Avg Deep Sleep"; color: Palette.muted; font-size: 11px; }
                        Text {
                            text: root.stats.deep-avg-label;
                            color: Palette.deep-sleep;
                            font-size: 18px; font-weight: 700;
                        }
                    }
                }
                // Stage mix
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Stage Mix"; color: Palette.muted; font-size: 11px; }
                        HorizontalLayout {
                            spacing: 8px;
                            HorizontalLayout {
                                spacing: 3px;
                                Text { text: "" + round(root.stats.light-pct) + "%"; color: Palette.accent; font-size: 14px; font-weight: 700; }
                                Text { text: "light"; color: Palette.muted; font-size: 10px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                spacing: 3px;
                                Text { text: "" + round(root.stats.deep-pct) + "%"; color: Palette.deep-sleep; font-size: 14px; font-weight: 700; }
                                Text { text: "deep"; color: Palette.muted; font-size: 10px; vertical-alignment: center; }
                            }
                            if root.stats.awake-pct > 0: HorizontalLayout {
                                spacing: 3px;
                                Text { text: "" + round(root.stats.awake-pct) + "%"; color: Palette.muted; font-size: 14px; font-weight: 700; }
                                Text { text: "awake"; color: Palette.muted; font-size: 10px; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            // Row 2: Avg Bedtime | Avg Wakeup
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Avg Bedtime"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.avg-bedtime; color: Palette.text; font-size: 16px; font-weight: 600; }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Avg Wake-up"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.avg-wakeup; color: Palette.text; font-size: 16px; font-weight: 600; }
                    }
                }
            }

            // Row 3: Highest | Lowest duration
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Longest Night"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.highest-dur; color: Palette.green; font-size: 16px; font-weight: 600; }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Shortest Night"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.lowest-dur; color: Palette.orange; font-size: 16px; font-weight: 600; }
                    }
                }
            }
        }
    }
}

// ─── Heart-rate trend chart ──────────────────────────────────────────────────

export component HeartTrendChart inherits VerticalLayout {
    in property <[HeartTrendPoint]> model;
    in property <string> average-path;
    in property <string> resting-path;
    in property <string> max-label;
    in property <string> mid-label;
    in property <string> min-label;
    in property <bool> has-data: false;

    Rectangle {
        background: Palette.surface; border-radius: 12px; height: 260px; clip: true;
        VerticalLayout {
            padding: 14px; spacing: 8px;

            HorizontalLayout {
                height: 22px;
                Text { text: "Heart Rate Trend"; color: Palette.text; font-size: 15px; font-weight: 700; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                HorizontalLayout {
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 4px;
                        Rectangle { width: 14px; height: 2px; background: Palette.red; y: 5px; }
                        Text { text: "Average"; color: Palette.muted; font-size: 10px; vertical-alignment: center; }
                    }
                    HorizontalLayout {
                        spacing: 4px;
                        Rectangle { width: 14px; height: 2px; background: Palette.accent; y: 5px; }
                        Text { text: "Resting"; color: Palette.muted; font-size: 10px; vertical-alignment: center; }
                    }
                }
            }

            if root.has-data: VerticalLayout {
                vertical-stretch: 1; spacing: 4px;
                HorizontalLayout {
                    height: 158px;
                    VerticalLayout {
                        width: 38px;
                        Text { text: root.max-label; color: Palette.muted; font-size: 9px; vertical-alignment: top; }
                        Rectangle { vertical-stretch: 1; }
                        Text { text: root.mid-label; color: Palette.muted; font-size: 9px; vertical-alignment: center; }
                        Rectangle { vertical-stretch: 1; }
                        Text { text: root.min-label; color: Palette.muted; font-size: 9px; vertical-alignment: bottom; }
                    }
                    Rectangle {
                        horizontal-stretch: 1; clip: true;
                        // Three quiet guide lines keep the shared BPM scale easy to read.
                        Path {
                            width: parent.width; height: parent.height;
                            commands: "M 0 0 L 100 0 M 0 50 L 100 50 M 0 100 L 100 100";
                            viewbox-width: 100; viewbox-height: 100;
                            fill: #00000000; stroke: #6a6a9040; stroke-width: 1px;
                        }
                        if root.average-path != "": Path {
                            width: parent.width; height: parent.height;
                            commands: root.average-path;
                            viewbox-width: 100; viewbox-height: 100;
                            fill: #00000000; stroke: Palette.red; stroke-width: 2px;
                            stroke-line-cap: round; stroke-line-join: round;
                        }
                        if root.resting-path != "": Path {
                            width: parent.width; height: parent.height;
                            commands: root.resting-path;
                            viewbox-width: 100; viewbox-height: 100;
                            fill: #00000000; stroke: Palette.accent; stroke-width: 2px;
                            stroke-line-cap: round; stroke-line-join: round;
                        }

                    }
                }
                HorizontalLayout {
                    padding-left: 38px;
                    for point in root.model: Text {
                        text: point.label; color: Palette.muted; font-size: 9px;
                        horizontal-stretch: 1; horizontal-alignment: center;
                    }
                }
            }
            if !root.has-data: Rectangle {
                vertical-stretch: 1;
                Text { text: "No heart-rate trend data for this period"; color: Palette.muted; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
            }
        }
    }
}

// ─── Heart-rate stats panel ──────────────────────────────────────────────────

export component HeartStatsPanel inherits VerticalLayout {
    in property <HeartStats> stats;
    in property <[HeartTrendPoint]> trend-model;
    in property <string> average-path;
    in property <string> resting-path;
    in property <string> trend-max-label;
    in property <string> trend-mid-label;
    in property <string> trend-min-label;
    in property <bool> trend-has-data: false;

    vertical-stretch: 1;
    padding-left: 16px; padding-right: 16px; padding-top: 8px; padding-bottom: 16px;
    spacing: 10px;

    HeartTrendChart {
        model: root.trend-model;
        average-path: root.average-path;
        resting-path: root.resting-path;
        max-label: root.trend-max-label;
        mid-label: root.trend-mid-label;
        min-label: root.trend-min-label;
        has-data: root.trend-has-data;
    }

    HorizontalLayout {
        Text { text: "Key Stats"; color: Palette.text; font-size: 15px; font-weight: 700; vertical-alignment: center; }
        Rectangle { horizontal-stretch: 1; }
    }

    Rectangle {
        background: Palette.surface; border-radius: 12px;
        VerticalLayout {
            padding: 14px; spacing: 10px;

            // Row 1: overall average across the full width
            Rectangle {
                horizontal-stretch: 1;
                background: #401e2a; border-radius: 8px;
                VerticalLayout {
                    padding: 10px; spacing: 4px;
                    Text { text: "Avg Heart Rate"; color: Palette.muted; font-size: 11px; }
                    Text { text: root.stats.average-label; color: Palette.red; font-size: 18px; font-weight: 700; }
                }
            }

            // Row 2: resting average | sleeping average
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Avg Resting HR"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.resting-label; color: Palette.accent; font-size: 18px; font-weight: 700; }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Avg Sleeping HR"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.sleeping-label; color: Palette.deep-sleep; font-size: 18px; font-weight: 700; }
                    }
                }
            }

            // Row 3: lowest sample | highest sample
            HorizontalLayout {
                spacing: 10px;
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Lowest HR"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.lowest-label; color: Palette.green; font-size: 18px; font-weight: 700; }
                    }
                }
                Rectangle {
                    horizontal-stretch: 1;
                    background: #1e1e40; border-radius: 8px;
                    VerticalLayout {
                        padding: 10px; spacing: 4px;
                        Text { text: "Highest HR"; color: Palette.muted; font-size: 11px; }
                        Text { text: root.stats.highest-label; color: Palette.orange; font-size: 18px; font-weight: 700; }
                    }
                }
            }
        }
    }
}
